# Copia esto a .env y llena las keys de los providers que vayas a usar.
# Solo necesitas la del provider que uses (default: anthropic).

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Modelo por defecto para el provider activo.
# SLAD_MODEL aplica a todos; las variables por provider tienen prioridad.
SLAD_DEFAULT_PROVIDER=cli
SLAD_WIKI_PATH=
SLAD_MODEL=MiniMax-M2.7
ANTHROPIC_MODEL=MiniMax-M2.7
OPENAI_MODEL=
GEMINI_MODEL=

# Agent local sin API key: invoca un binario autenticado por login.
# En uso normal, prefiere `slad ... --agent codex` o `slad ... --agent claude`.
# Si no defines SLAD_CLI_BINARY, slad intenta auto-detectar `codex` y luego `claude`.
# Preset recomendado para Codex instalado localmente:
SLAD_CLI_BINARY=codex
SLAD_CLI_ARGS=exec --skip-git-repo-check --color never
SLAD_CLI_PROMPT_MODE=stdin
SLAD_CLI_MODEL_ARG=--model
CLI_MODEL=
SLAD_CLI_TIMEOUT_MS=120000
# Por defecto, el provider cli NO hereda API keys del .env para no interferir
# con logins locales de Claude/Codex. Cambia a true solo si tu binario lo requiere.
SLAD_CLI_INHERIT_API_KEYS=false
